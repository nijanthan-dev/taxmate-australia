{
  "description": "Clean temporary official-source cache after Codex sessions.",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PLUGIN_ROOT:-$PWD}/scripts/clean-source-cache.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
